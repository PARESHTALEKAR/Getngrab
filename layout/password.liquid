<!DOCTYPE html>
<html>
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ shop.name }} – Coming Soon</title>
  <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@900&family=Barlow:wght@400&display=swap" rel="stylesheet">
  {{ content_for_header }}
  <style>
    *{margin:0;padding:0;box-sizing:border-box}
    body{font-family:'Barlow',sans-serif;background:#0a0a0a;color:#fff;min-height:100vh;display:flex;align-items:center;justify-content:center;text-align:center}
    .logo{font-family:'Barlow Condensed',sans-serif;font-size:52px;font-weight:900;letter-spacing:-2px;margin-bottom:20px}
    .logo span{color:#e8001d}
    h1{font-family:'Barlow Condensed',sans-serif;font-size:32px;font-weight:900;text-transform:uppercase;margin-bottom:12px}
    p{color:#666;margin-bottom:32px}
    input{background:#1a1a1a;border:1px solid #333;color:#fff;padding:12px 18px;font-size:15px;width:260px;outline:none;margin-right:8px}
    input:focus{border-color:#e8001d}
    button{background:#e8001d;color:#fff;border:none;padding:12px 24px;font-family:'Barlow Condensed',sans-serif;font-size:15px;font-weight:700;letter-spacing:1px;cursor:pointer;text-transform:uppercase}
    button:hover{background:#c0001a}
    .err{color:#e8001d;font-size:13px;margin-top:12px}
  </style>
</head>
<body>
  <div>
    <div class="logo">GET<span>N</span>GRAB</div>
    <h1>{{ 'general.password_page.login_form_heading' | t }}</h1>
    <p>{{ 'general.password_page.login_prompt' | t }}</p>
    {% form 'storefront_password' %}
      {{ form.errors | default_errors }}
      <div>
        <input type="password" name="password" placeholder="{{ 'general.password_page.login_form_password_label' | t }}" autofocus>
        <button type="submit">{{ 'general.password_page.login_form_submit' | t }}</button>
      </div>
    {% endform %}
  </div>
</body>
</html>
