<div style="text-align:center;padding:80px 24px;max-width:440px;margin:0 auto">
  <h1 style="font-family:var(--font-head);font-size:32px;font-weight:900;text-transform:uppercase;margin-bottom:28px">Sign In</h1>
  {% form 'customer_login' %}
    {{ form.errors | default_errors }}
    <div class="form-group"><label>Email</label><input name="customer[email]" type="email" placeholder="you@example.com" autocomplete="email"></div>
    <div class="form-group"><label>Password</label><input name="customer[password]" type="password" placeholder="••••••••" autocomplete="current-password"></div>
    <button type="submit" class="btn btn-red" style="width:100%;padding:13px;margin-bottom:14px">SIGN IN</button>
    <div style="display:flex;justify-content:space-between;font-size:13px;color:var(--mid)">
      <a href="/account/register" style="color:inherit">Create account →</a>
      <a href="/account/forgot_password" style="color:inherit">Forgot password?</a>
    </div>
  {% endform %}
</div>
