<div style="text-align:center;padding:80px 24px;max-width:480px;margin:0 auto">
  <h1 style="font-family:var(--font-head);font-size:32px;font-weight:900;text-transform:uppercase;margin-bottom:28px">Create Account</h1>
  {% form 'create_customer' %}
    {{ form.errors | default_errors }}
    <div class="form-row">
      <div class="form-group"><label>First Name</label><input name="customer[first_name]" placeholder="Raj" autocomplete="given-name"></div>
      <div class="form-group"><label>Last Name</label><input name="customer[last_name]" placeholder="Kumar" autocomplete="family-name"></div>
    </div>
    <div class="form-group"><label>Email</label><input name="customer[email]" type="email" placeholder="raj@example.com" autocomplete="email"></div>
    <div class="form-group"><label>Password</label><input name="customer[password]" type="password" placeholder="Min 8 characters" autocomplete="new-password"></div>
    <button type="submit" class="btn btn-red" style="width:100%;padding:13px;margin-bottom:14px">CREATE ACCOUNT</button>
    <a href="/account/login" style="font-size:13px;color:var(--mid)">Already have an account? Sign in →</a>
  {% endform %}
</div>
