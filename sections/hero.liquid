<section class="hero">
  <div class="hero-left">
    <div class="hero-tag">🔥 {{ section.settings.hero_tag }}</div>
    <h1>
      {{ section.settings.hero_line1 }}<br>
      {{ section.settings.hero_line2 }}<br>
      <em>{{ section.settings.hero_line3 }}</em>
    </h1>
    <p class="hero-sub">{{ section.settings.hero_subtitle }}</p>
    <div class="hero-btns">
      <a href="{{ section.settings.cta1_link }}" class="btn btn-red">{{ section.settings.cta1_text }}</a>
      <a href="{{ section.settings.cta2_link }}" class="btn btn-outline" style="color:#fff;border-color:#fff">{{ section.settings.cta2_text }}</a>
    </div>
    <div class="hero-stats">
      <div>
        <div class="stat-num">{{ section.settings.stat1_num }}</div>
        <div class="stat-lbl">{{ section.settings.stat1_lbl }}</div>
      </div>
      <div>
        <div class="stat-num">{{ section.settings.stat2_num }}</div>
        <div class="stat-lbl">{{ section.settings.stat2_lbl }}</div>
      </div>
      <div>
        <div class="stat-num">{{ section.settings.stat3_num }}</div>
        <div class="stat-lbl">{{ section.settings.stat3_lbl }}</div>
      </div>
    </div>
  </div>
  <div class="hero-right" style="position:relative;overflow:hidden;">
    {% if section.settings.hero_image != blank %}
      <img src="{{ section.settings.hero_image | img_url: '1200x' }}"
           alt="{{ section.settings.hero_image.alt | escape }}"
           style="width:100%;height:100%;object-fit:cover;object-position:center;display:block;"
           loading="eager">
    {% else %}
      <img src="https://cdn.shopify.com/s/files/1/0570/7389/3509/t/1/assets/02-04-2025-202143-dulopa_photo1.png"
           alt="GetNGrab Featured Shoe"
           style="width:100%;height:100%;object-fit:cover;object-position:center;display:block;"
           onerror="this.src='https://images.unsplash.com/photo-1606107557195-0e29a4b5b4aa?w=900&q=85'">
    {% endif %}
    <div style="position:absolute;inset:0;background:linear-gradient(to right,rgba(0,0,0,0.55) 0%,transparent 55%)"></div>
    {% if section.settings.hero_badge != blank %}
      <div style="position:absolute;bottom:28px;right:28px;background:var(--red);color:#fff;font-family:var(--font-head);font-size:12px;font-weight:700;letter-spacing:2px;padding:7px 18px;text-transform:uppercase;">
        {{ section.settings.hero_badge }}
      </div>
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Hero Banner",
  "settings": [
    { "type": "text", "id": "hero_tag", "label": "Tag line", "default": "New Drop 2025" },
    { "type": "text", "id": "hero_line1", "label": "Headline line 1", "default": "RUN" },
    { "type": "text", "id": "hero_line2", "label": "Headline line 2", "default": "YOUR" },
    { "type": "text", "id": "hero_line3", "label": "Headline line 3 (accent color)", "default": "WORLD" },
    { "type": "textarea", "id": "hero_subtitle", "label": "Subtitle", "default": "Performance footwear engineered for champions. Every step, every stride — grab the edge before it's gone." },
    { "type": "text", "id": "cta1_text", "label": "Primary CTA text", "default": "SHOP NOW" },
    { "type": "url", "id": "cta1_link", "label": "Primary CTA link" },
    { "type": "text", "id": "cta2_text", "label": "Secondary CTA text", "default": "RUNNING COLLECTION" },
    { "type": "url", "id": "cta2_link", "label": "Secondary CTA link" },
    { "type": "image_picker", "id": "hero_image", "label": "Hero image" },
    { "type": "text", "id": "hero_badge", "label": "Badge text (bottom right)", "default": "748 SOLD →" },
    { "type": "text", "id": "stat1_num", "label": "Stat 1 number", "default": "500+" },
    { "type": "text", "id": "stat1_lbl", "label": "Stat 1 label", "default": "Styles" },
    { "type": "text", "id": "stat2_num", "label": "Stat 2 number", "default": "2M+" },
    { "type": "text", "id": "stat2_lbl", "label": "Stat 2 label", "default": "Happy Feet" },
    { "type": "text", "id": "stat3_num", "label": "Stat 3 number", "default": "48hr" },
    { "type": "text", "id": "stat3_lbl", "label": "Stat 3 label", "default": "Delivery" }
  ],
  "presets": [{ "name": "Hero Banner" }]
}
{% endschema %}
