<section class="section section-gray">
  <div class="sec-head">
    <h2 class="sec-title">Best <span>Sellers</span></h2>
    <a class="view-all" href="/collections/best-sellers">View All →</a>
  </div>
  <div class="prod-grid">
    {% assign bs_collection = collections[section.settings.collection] %}
    {% if bs_collection != blank %}
      {% for product in bs_collection.products limit: section.settings.products_limit %}
        {% render 'product-card', product: product %}
      {% endfor %}
    {% else %}
      {% for i in (1..4) %}
        {% render 'product-card-placeholder' %}
      {% endfor %}
    {% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Best Sellers",
  "settings": [
    { "type": "collection", "id": "collection", "label": "Collection", "info": "Select the Best Sellers collection" },
    { "type": "range", "id": "products_limit", "min": 2, "max": 12, "step": 2, "label": "Number of products", "default": 4 }
  ],
  "presets": [{ "name": "Best Sellers" }]
}
{% endschema %}
