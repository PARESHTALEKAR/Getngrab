<style>
  .cats-bar {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    padding: 10px 0;
    scrollbar-width: none;
  }

  .cats-bar::-webkit-scrollbar {
    display: none;
  }

  .cat-pill {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 10px 18px;
    border-radius: 999px;
    background: #f5f5f5;
    color: #000;
    text-decoration: none;
    font-size: 14px;
    font-weight: 500;
    white-space: nowrap;
    cursor: pointer;
    transition: all 0.2s ease;
  }

  .cat-pill:hover {
    background: #000;
    color: #fff;
  }
</style>

